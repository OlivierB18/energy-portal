# Copy this file to .env and fill in the values

# ─── Database ────────────────────────────────────────────────────────────────
# Local development: use a free cloud Postgres (Neon, Supabase) or a local
# Postgres instance.  SQLite is NOT supported on Netlify.
#
# Neon example:
#   DATABASE_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"
#
# Local Postgres example:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/energy_portal"
DATABASE_URL="postgresql://user:password@host:5432/energy_portal?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Local development
# NEXTAUTH_URL="http://localhost:3000"

# Production — replace with your actual Netlify URL
NEXTAUTH_URL="https://your-site.netlify.app"
