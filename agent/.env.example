# Auth0 configuration (same as main app)
AUTH0_DOMAIN=
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_APP_CLIENT_ID=

# Your environment ID
HOMEWIZARD_ENVIRONMENT_ID=

# Polling interval (default 10000 = 10 seconds)
HOMEWIZARD_POLL_MS=10000

# Netlify ingest function
INGEST_URL=https://brouwerems.netlify.app/.netlify/functions/ingest-device-data
INGEST_API_KEY=
