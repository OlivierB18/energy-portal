# Auth0 configuration (copied from main app .env)
AUTH0_DOMAIN=
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_APP_CLIENT_ID=

# Environment ID (e.g., 'vacation' for 'Brouwer TEST')
ENVIRONMENT_ID=

# Optional direct HA connection override (if set, Auth0 metadata lookup is skipped)
HA_URL=
HA_TOKEN=

# Device token reserved for future Plan Foxtrot device authentication
DEVICE_TOKEN=

# Polling interval in milliseconds (default 10000 = 10 seconds)
POLL_INTERVAL_MS=10000

# Aggregation interval in milliseconds (default 900000 = 15 minutes)
AGGREGATE_INTERVAL_MS=900000

# Netlify ingest endpoint
INGEST_URL=https://brouwerems.netlify.app/.netlify/functions/ingest-device-data
INGEST_API_KEY=
